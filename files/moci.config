config ui 'features'
	option dashboard '1'
	option devices '1'
	option network '1'
	option traffic_history '1'
	option monitoring '1'
	option netify '1'
	option show_lan_ip '0'
	option colorful_graphs '0'
	option wireless '1'
	option firewall '1'
	option dhcp '1'
	option dns '1'
	option adblock_fast '1'
	option pbr '1'
	option wireguard '1'
	option qos '1'
	option ddns '1'
	option diagnostics '1'
	option quarantine '1'
	option system '1'
	option backup '1'
	option packages '1'
	option services '1'
	option ssh_keys '1'
	option storage '1'
	option leds '1'
	option firmware '1'

config ui 'presets'
	option description 'Presets for common configurations'

config preset 'full_router'
	option name 'Full Router'
	option description 'All features enabled (default)'

config preset 'ap_switch'
	option name 'AP/Switch (Layer 2)'
	option description 'Disable L3 features: firewall, dhcp, qos, wireguard, ddns'
	option firewall '0'
	option dhcp '0'
	option qos '0'
	option wireguard '0'
	option ddns '0'
	option dns '0'
	option adblock_fast '0'
	option pbr '0'
	option quarantine '0'

config preset 'minimal'
	option name 'Minimal'
	option description 'Dashboard and system settings only'
	option devices '0'
	option network '0'
	option traffic_history '0'
	option monitoring '0'
	option netify '0'
	option wireless '0'
	option firewall '0'
	option dhcp '0'
	option dns '0'
	option adblock_fast '0'
	option pbr '0'
	option wireguard '0'
	option qos '0'
	option ddns '0'
	option diagnostics '0'
	option quarantine '0'
	option backup '0'
	option packages '0'
	option services '0'
	option ssh_keys '0'
	option storage '0'
	option leds '0'
	option firmware '0'

config netify 'collector'
	option enabled '1'
	option host '127.0.0.1'
	option port '7150'
	option db_path '/tmp/moci-netify.sqlite'
	option retention_rows '500000'
	option stream_timeout '45'
	option exclude_protocols 'MDNS,DNS,QUIC,DHCPv6,ICMP'
	option ignore_wan_source '1'

config ping 'ping_monitor'
	option enabled '1'
	option target '1.1.1.1'
	option interval '60'
	option threshold '100'
	option timeout '2'
	option output_file '/tmp/moci-ping-monitor.txt'
	option max_lines '2000'

config speedtest 'speedtest_monitor'
	option enabled '1'
	option run_hour '3'
	option run_minute '15'
	option bin '/usr/bin/speedtest'
	option output_file '/tmp/moci-speedtest-monitor.txt'
	option max_lines '365'

config state_backup 'state_backup'
	option backup_time '240'
	option state_dir '/overlay/moci-state'

config quarantine 'quarantine'
	option enabled '0'
	option interval '15'
	option leases_file '/tmp/dhcp.leases'
	option state_file '/tmp/moci-quarantine-known.txt'
	option rule_prefix 'moci_quarantine_'
