config ui 'features'
	option dashboard '1'
	option devices '1'
	option network '1'
	option traffic_history '1'
	option monitoring '1'
	option netify '1'
	option show_lan_ip '0'
	option wireless '1'
	option firewall '1'
	option dhcp '1'
	option dns '1'
	option wireguard '1'
	option qos '1'
	option ddns '1'
	option diagnostics '1'
	option system '1'
	option backup '1'
	option packages '1'
	option services '1'
	option ssh_keys '1'
	option storage '1'
	option leds '1'
	option firmware '1'

config ui 'presets'
	option description 'Presets for common configurations'

config preset 'full_router'
	option name 'Full Router'
	option description 'All features enabled (default)'

config preset 'ap_switch'
	option name 'AP/Switch (Layer 2)'
	option description 'Disable L3 features: firewall, dhcp, qos, wireguard, ddns'
	option firewall '0'
	option dhcp '0'
	option qos '0'
	option wireguard '0'
	option ddns '0'
	option dns '0'

config preset 'minimal'
	option name 'Minimal'
	option description 'Dashboard and system settings only'
	option devices '0'
	option network '0'
	option traffic_history '0'
	option monitoring '0'
	option netify '0'
	option wireless '0'
	option firewall '0'
	option dhcp '0'
	option dns '0'
	option wireguard '0'
	option qos '0'
	option ddns '0'
	option diagnostics '0'
	option backup '0'
	option packages '0'
	option services '0'
	option ssh_keys '0'
	option storage '0'
	option leds '0'
	option firmware '0'

config netify 'collector'
	option enabled '1'
	option host '127.0.0.1'
	option port '7150'
	option output_file '/tmp/moci-netify-flow.jsonl'
	option max_lines '5000'

config ping 'ping_monitor'
	option enabled '1'
	option target '1.1.1.1'
	option interval '60'
	option timeout '2'
	option output_file '/tmp/moci-ping-monitor.txt'
	option max_lines '2000'
