#!/bin/sh /etc/rc.common

START=96
STOP=10
USE_PROCD=1

PROG="/usr/bin/moci-connection-flow-collector"

start_service() {
	local enabled
	enabled="$(uci -q get moci.connection_flows.enabled 2>/dev/null || echo 1)"
	[ "$enabled" = "0" ] && return 0
	[ -x "$PROG" ] || return 1

	procd_open_instance
	# Launch via /bin/sh for compatibility on builds where direct script exec via procd fails.
	procd_set_param command /bin/sh "$PROG" --daemon
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 0
	procd_set_param stderr 0
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger "moci"
}
