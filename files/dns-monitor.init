#!/bin/sh /etc/rc.common

START=96
STOP=10
USE_PROCD=1

PROG="/usr/bin/moci-dns-monitor"

start_service() {
	local enabled
	enabled="$(uci -q get moci.dns_monitor.enabled 2>/dev/null || echo 1)"
	[ "$enabled" = "0" ] && return 0

	procd_open_instance
	procd_set_param command "$PROG"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger "moci"
}
