#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1
PROG="/usr/bin/moci-device-quarantine"

is_enabled() {
	local feature enabled
	feature="$(uci -q get moci.features.quarantine 2>/dev/null || echo 1)"
	enabled="$(uci -q get moci.quarantine.enabled 2>/dev/null || echo 0)"
	[ "$feature" = "1" ] && [ "$enabled" = "1" ]
}

start_service() {
	is_enabled || return 0
	procd_open_instance
	procd_set_param command "$PROG" --daemon
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	return 0
}

service_triggers() {
	procd_add_reload_trigger "moci"
}
